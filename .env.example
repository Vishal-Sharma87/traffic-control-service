# ==========================================
# TRAFFIC CONTROL QUEUE SETTINGS
# ==========================================
MAIN_QUEUE_CAPACITY=5

# ==========================================
# SYSTEM & QUEUE MESSAGES
# ==========================================
MAIN_QUEUE_FULL_ERROR_MESSAGE="Request cannot be accepted at the moment due to high load. Please try again later."
MAIN_QUEUE_EMPTY_ERROR_MESSAGE="No jobs are currently available in the queue. Retrying..."
JOB_EXPIRED_OR_NOT_EXISTS_ERROR_MESSAGE="Job is either expired or does not exist"
JOB_COMPLETED_MESSAGE="Job completed successfully"
JOB_PENDING_MESSAGE="Job is pending and will be processed shortly"
JOB_PROCESSING_MESSAGE="Job is currently being processed"
JOB_NEED_DISCARD_ERROR_MESSAGE="Job has exceeded the maximum retry limit and needs to be discarded."
JOB_FAILED_MESSAGE="Job has permanently failed and no result is available. Please submit a new request."
JOB_METADATA_NULL_ERROR_MESSAGE="Job metadata is null. Unable to save the result."
SYSTEM_UNHEALTHY_ERROR_MESSAGE="System is currently unavailable due to high load. Please try again later."
FAILED_METADATA_TTL=600
COMPLETED_METADATA_TTL=86400

# ==========================================
# JOB TIER CONFIGURATIONS
# ==========================================
PAID_MAX_PROCESSING_TIME=50000
PAID_MAX_HEARTBEAT_TIMEOUT=15000
PAID_MAX_RETRIES_PER_JOB=5

UNPAID_MAX_PROCESSING_TIME=20000
UNPAID_MAX_HEARTBEAT_TIMEOUT=6000
UNPAID_MAX_RETRIES_PER_JOB=2

PUBLIC_MAX_PROCESSING_TIME=10000
PUBLIC_MAX_HEARTBEAT_TIMEOUT=3000
PUBLIC_MAX_RETRIES_PER_JOB=1

# ==========================================
# SCHEDULER & SYSTEM HEALTH
# ==========================================
STUCK_SCHEDULER_FLOOR_MS=5000
STUCK_SCHEDULER_CEILING_MS=120000
CRASHED_SCHEDULER_FLOOR_MS=3000
CRASHED_SCHEDULER_CEILING_MS=60000
SYSTEM_FAIL_CAP=5
SYSTEM_THRESHOLD=3

# ==========================================
# THREAD POOL CONFIGURATIONS
# ==========================================
JOB_WORKERS_COUNT=3
HEARTBEAT_WORKER_COUNT=3
HEARTBEAT_INITIAL_DELAY=0
HEARTBEAT_INTERVAL=500

# ==========================================
# INFRASTRUCTURE CREDENTIALS (SENSITIVE)
# ==========================================
# Database Configuration
MYSQL_DATABASE=traffic_control_service_db
MYSQL_ROOT_PASSWORD=your_secure_password_here

# Redis Configuration
# Note: Use "redis" as host if running within Docker Compose, or "localhost" for local dev.
REDIS_HOST=redis
REDIS_PORT=6379